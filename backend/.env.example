# Application environment: development | staging | production
APP_ENV=development

# PostgreSQL async connection URL
DATABASE_URL=postgresql+asyncpg://consulting:consulting@localhost:5432/consulting

# Fernet symmetric encryption key (used to encrypt user secrets).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-me-with-a-generated-fernet-key

# Maximum time to wait for one LLM provider request.
# Longer consulting stages can take more than a minute on larger models.
LLM_TIMEOUT_SEC=300

# Maximum output tokens for one LLM response.
# Stage agents return artifact content as structured JSON, so the cap must be generous.
LLM_MAX_TOKENS=16000
