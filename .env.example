# Consulting Research Agent — root environment example.
#
# Copy to `.env` at the repo root and fill in real values.
# This file is the consolidated reference for env vars used across
# backend (FastAPI) and infra (Docker Compose). Frontend uses its own
# `frontend/.env.local` for VITE_* / NEXT_PUBLIC_* variables.

# Application environment: development | staging | production
APP_ENV=development

# PostgreSQL async connection URL.
# Matches credentials defined in infra/docker-compose.yml.
DATABASE_URL=postgresql+asyncpg://consulting:consulting@localhost:5432/consulting

# Fernet symmetric encryption key (used to encrypt user secrets at rest).
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FERNET_KEY=replace-me-with-a-generated-fernet-key

# Maximum time to wait for one LLM provider request.
# Longer consulting stages can take more than a minute on larger models.
LLM_TIMEOUT_SEC=300

# Maximum output tokens for one LLM response.
# Stage agents return artifact content as structured JSON, so the cap must be generous.
LLM_MAX_TOKENS=16000
